{
  "name": "aegis-intel",
  "version": "1.0.0",
  "description": "Military Cyber Intelligence Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "electron-dev": "electron .",
    "build": "npm run react-build && electron-builder",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "^0.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "wait-on": "^7.2.0"
  },
  "homepage": "./",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead"
    ],
    "development": [
      "last 1 chrome version"
    ]
  },
  "build": {
    "appId": "com.aegis.intel",
    "productName": "AEGIS Intel",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
